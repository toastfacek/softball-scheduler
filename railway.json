{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "Dockerfile.railway"
  },
  "deploy": {
    "startCommand": "pnpm cron:reminders",
    "restartPolicyType": "NEVER",
    "numReplicas": 1,
    "cronSchedule": "0 14 * * *"
  }
}

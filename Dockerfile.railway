FROM node:22-alpine

WORKDIR /app

RUN corepack enable

COPY package.json pnpm-lock.yaml pnpm-workspace.yaml ./
RUN pnpm install --frozen-lockfile --prod=false

COPY drizzle ./drizzle
COPY drizzle.config.ts ./
COPY src ./src
COPY tsconfig.json ./

ENV NODE_ENV=production

CMD ["pnpm", "cron:reminders"]
